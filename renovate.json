{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "enabledManagers": ["custom.regex"],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Bump @coree-ai/coree pin in all text files",
      "managerFilePatterns": [
        "/\\.(?:md|json|toml|rs|ts|js|mjs|ya?ml)$/"
      ],
      "matchStrings": [
        "@coree-ai\\/coree@(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)"
      ],
      "depNameTemplate": "@coree-ai/coree",
      "datasourceTemplate": "npm",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "description": "Bump COREE_VERSION constant in opencode src/index.ts",
      "managerFilePatterns": [
        "/src\\/index\\.ts$/"
      ],
      "matchStrings": [
        "COREE_VERSION = \"(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)\""
      ],
      "depNameTemplate": "@coree-ai/coree",
      "datasourceTemplate": "npm",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "description": "Bump nX.Y.Z shorthand in gemini-extension.json",
      "managerFilePatterns": [
        "/gemini-extension\\.json$/"
      ],
      "matchStrings": [
        "\"n(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)\""
      ],
      "depNameTemplate": "@coree-ai/coree",
      "datasourceTemplate": "npm",
      "versioningTemplate": "semver"
    }
  ],
  "packageRules": [
    {
      "matchPackageNames": ["@coree-ai/coree"],
      "automerge": false,
      "labels": ["dependencies"],
      "prBodyNotes": ["Automated pin propagation from coree-ai/coree release."],
      "postUpgradeTasks": {
        "commands": [
          "node scripts/renovate-post-upgrade.mjs {{{currentVersion}}} {{{newVersion}}}"
        ],
        "fileFilters": [
          "package-lock.json",
          "package.json",
          "plugin.json",
          ".claude-plugin/plugin.json",
          ".codex-plugin/plugin.json",
          "gemini-extension.json",
          "extension.toml"
        ],
        "executionMode": "branch"
      }
    }
  ]
}
